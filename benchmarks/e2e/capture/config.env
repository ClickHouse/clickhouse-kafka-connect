# Repo config for the Kafka Connect sink benchmark capture pipeline (task 30).
# `source` this file before running the capture scripts:  . config.env
#
# It carries ONLY non-secret, repo-controlled facts. Secrets (CH host / user /
# password, DWH role arn, AWS creds) are NEVER placed here — they come from CI
# secrets / the environment (see benchmarks/e2e/sql/README.md CI secrets table).

# --- Contract §1.1 mandatory scope keys (MUST be set from config, never inline) ---
# The Kafka benchmark's dedicated target is a us-east-2 staging Cloud service
# (plan §4, contract §1.1). insert_run_record.py reads these and HARD-FAILS if
# either is empty; it also injects them into perf.runs.runtime.
export TARGET_REGION="us-east-2"
export ENVIRONMENT_CLASS="staging"

# --- Connector identity (contract §1, plan §3) ---
# Written to perf.runs.connector; distinguishes Kafka rows from Spark rows and
# aliases the headline in the cross-connector Tab 5 view.
export CONNECTOR="kafka-connect"

# --- query_log filter (Kafka adaptation, see 11_insert_from_query_log.sql) ---
# The connector's ClickHouse user; scopes the query_log capture to the sink's
# inserts on top of the has(tables) table filter. Empty => table scope only.
# Set to the benchmark user created by bootstrap/01_create_benchmark_user.sql.
# Task 31's first manual run validates this against live sink query_log rows.
export QUERY_LOG_USER="kafka_benchmark"

# --- Target database/table names (plan §4 Tiers) ---
# Tier 1 real MergeTree target is clickbench.hits; Tier 0 Null target is
# clickbench.hits_null. The orchestrator overrides CH_TABLE per tier.
export CH_DATABASE="clickbench"
export CH_TABLE="hits"
